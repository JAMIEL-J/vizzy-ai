# =============================================================================
# Vizzy Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Vizzy
APP_VERSION=1.0.0
ENVIRONMENT=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# For SQLite (default - easiest for development)
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/vizzy.db

# For PostgreSQL (production)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vizzy
# DB_USER=postgres
# DB_PASSWORD=your_secure_password_here
# DB_POOL_SIZE=5
# DB_POOL_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Authentication Settings
# -----------------------------------------------------------------------------
# CRITICAL: Change this secret key in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
STORAGE_DATA_DIR=data/uploads
STORAGE_MAX_FILE_SIZE_MB=100

# -----------------------------------------------------------------------------
# LLM Provider Settings
# -----------------------------------------------------------------------------
# Primary: Google Gemini Flash (recommended for free tier)
LLM_GEMINI_API_KEY=your_gemini_api_key_here
LLM_GEMINI_MODEL=gemini-1.5-flash

# Secondary: Groq (for faster responses)
LLM_GROQ_API_KEY=your_groq_api_key_here
LLM_GROQ_MODEL=llama3-70b-8192

# Fallback: Gemini Flash (faster, cheaper)
LLM_GEMINI_FALLBACK_API_KEY=your_gemini_flash_api_key_here
LLM_GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# Groq chat/sql model
LLM_GROQ_CHAT_MODEL=openai/gpt-oss-120b

# TOKEN OPTIMIZATION FOR FREE TIER
# Adjust these to control token usage:
# - Lower max_tokens = shorter responses, less cost
# - Lower max_rows_sample = less data sent, less cost
# - Enable caching = fewer repeat API calls

LLM_MAX_TOKENS=1024                   # Global output budget
LLM_MAX_INPUT_TOKENS=4096             # Global input budget (non-SQL)
LLM_MAX_TOKENS_SQL=384                # SQL/chat output budget
LLM_MAX_INPUT_TOKENS_SQL=1400         # SQL/chat input budget
LLM_TEMPERATURE=0.3                   # Default: 0.3 (range: 0.0-1.0)
LLM_ENABLE_CACHING=true               # Enable response caching
LLM_CACHE_TTL_SECONDS=3600            # Cache lifetime (1 hour)
LLM_MAX_ROWS_SAMPLE=50                # Max rows to send to LLM
LLM_MAX_COLUMNS_DESCRIBE=12           # Max columns to describe

# LLM Retry Settings
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=30
