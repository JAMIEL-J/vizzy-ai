# Vizzy Prototype Configuration
# Copy this file to .env and fill in the actual values

# --- Database ---
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/vizzy.db

# --- Auth ---
AUTH_SECRET_KEY=your_secure_random_secret_key_here
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Storage ---
STORAGE_DATA_DIR=./data/uploads
STORAGE_DUCKDB_PATH=./data/vizzy_analytics.duckdb

# --- LLM Provider (Groq) ---
LLM_PRIMARY_PROVIDER=groq
LLM_GROQ_API_KEY=your_groq_api_key_here
LLM_GROQ_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3
